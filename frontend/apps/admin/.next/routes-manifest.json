{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:8080/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/gyms/[gymId]",
      "regex": "^/gyms/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgymId": "nxtPgymId"
      },
      "namedRegex": "^/gyms/(?<nxtPgymId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/analytics",
      "regex": "^/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/analytics(?:/)?$"
    },
    {
      "page": "/audit",
      "regex": "^/audit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/audit(?:/)?$"
    },
    {
      "page": "/content",
      "regex": "^/content(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/content(?:/)?$"
    },
    {
      "page": "/coupons",
      "regex": "^/coupons(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/coupons(?:/)?$"
    },
    {
      "page": "/create-gym",
      "regex": "^/create\\-gym(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/create\\-gym(?:/)?$"
    },
    {
      "page": "/demo-accounts",
      "regex": "^/demo\\-accounts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo\\-accounts(?:/)?$"
    },
    {
      "page": "/demo-requests",
      "regex": "^/demo\\-requests(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo\\-requests(?:/)?$"
    },
    {
      "page": "/discounts",
      "regex": "^/discounts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/discounts(?:/)?$"
    },
    {
      "page": "/gyms",
      "regex": "^/gyms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/gyms(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/media",
      "regex": "^/media(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/media(?:/)?$"
    },
    {
      "page": "/plans",
      "regex": "^/plans(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/plans(?:/)?$"
    },
    {
      "page": "/system",
      "regex": "^/system(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/system(?:/)?$"
    },
    {
      "page": "/users",
      "regex": "^/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/users(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}