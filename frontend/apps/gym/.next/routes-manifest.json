{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:8080/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/members/[memberId]",
      "regex": "^/members/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmemberId": "nxtPmemberId"
      },
      "namedRegex": "^/members/(?<nxtPmemberId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/programs/[programId]",
      "regex": "^/programs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprogramId": "nxtPprogramId"
      },
      "namedRegex": "^/programs/(?<nxtPprogramId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/trainers/[trainerId]",
      "regex": "^/trainers/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtrainerId": "nxtPtrainerId"
      },
      "namedRegex": "^/trainers/(?<nxtPtrainerId>[^/]+?)(?:/)?$"
    }
  ],
